NODE_ENV=development
PORT=4000
# local or Atlas URI
MONGODB_URI=mongodb://127.0.0.1:27017/finance_dashboard
# Driver pool (tune under load; defaults are safe for local dev)
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_MIN_POOL_SIZE=0
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
# Optional Redis: shared rate-limit counters + dashboard summary cache (omit for local dev / CI)
# REDIS_URL=redis://127.0.0.1:6379
# Dashboard cache TTL when Redis is set (seconds, max 86400). Default 60.
# DASHBOARD_CACHE_TTL_SECONDS=60
JWT_SECRET=
# In production (NODE_ENV=production), JWT_SECRET must be at least 32 characters unless overridden:
# JWT_SECRET_MIN_LENGTH=32
JWT_EXPIRES_IN=7d
# Optional extra allowed origin for CORS (e.g. another deployed app).
# Local 3000 and your Vercel URL (via VERCEL_URL) are already allowed when unset.
# CLIENT_ORIGIN=
# Optional rate limits (per IP, sliding 15-minute window). Defaults: auth 60, general API 300.
# For Postman rate-limit checks locally, try RATE_LIMIT_AUTH_MAX=3 (4th /api/auth/* hit → 429).
# RATE_LIMIT_AUTH_MAX=60
# RATE_LIMIT_API_MAX=300
# TRUST_PROXY=1
